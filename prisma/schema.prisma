generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model categories {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(255)
  description String?
  created_at  DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?     @default(now()) @db.Timestamptz(6)
  spare_parts spare_parts[]
}

model customers {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(255)
  phone        String?        @db.VarChar(50)
  email        String?        @db.VarChar(255)
  address      String?
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?      @default(now()) @db.Timestamptz(6)
  deleted_at   DateTime?      @db.Timestamptz(6)
  transactions transactions[]
  vehicles     vehicles[]
}

model opname_items {
  id             Int          @id @default(autoincrement())
  opname_id      Int?
  spare_part_id  Int?
  system_count   Int          @default(0)
  physical_count Int?
  difference     Int?         @default(dbgenerated("(physical_count - system_count)"))
  note           String?
  created_at     DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?    @default(now()) @db.Timestamptz(6)
  opnames        opnames?     @relation(fields: [opname_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  spare_parts    spare_parts? @relation(fields: [spare_part_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([opname_id, spare_part_id])
}

model opnames {
  id           Int            @id @default(autoincrement())
  user_id      Int?
  session_name String         @db.VarChar(255)
  status       String?        @default("open") @db.VarChar(50)
  opened_at    DateTime?      @default(now()) @db.Timestamptz(6)
  closed_at    DateTime?      @db.Timestamptz(6)
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?      @default(now()) @db.Timestamptz(6)
  opname_items opname_items[]
  users        users?         @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model settings {
  id               Int       @id @default(autoincrement())
  name             String?   @default("Bengkel AutoService") @db.VarChar(255)
  address          String?
  phone            String?   @db.VarChar(50)
  logo_url         String?
  wa_gateway_token String?
  wa_target_number String?   @db.VarChar(50)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
}

model spare_parts {
  id                Int                 @id @default(autoincrement())
  category_id       Int?
  name              String              @db.VarChar(255)
  sku               String              @unique @db.VarChar(100)
  barcode_value     String              @unique @db.VarChar(100)
  barcode_image_url String?
  cost_price        Decimal             @default(0) @db.Decimal(15, 2)
  sell_price        Decimal             @default(0) @db.Decimal(15, 2)
  current_stock     Int                 @default(0)
  minimum_stock     Int                 @default(0)
  unit              String?             @default("pcs") @db.VarChar(50)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  deleted_at        DateTime?           @db.Timestamptz(6)
  opname_items      opname_items[]
  categories        categories?         @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  stock_movements   stock_movements[]
  transaction_items transaction_items[]
  wa_notifications  wa_notifications[]
}

model stock_movements {
  id             Int          @id @default(autoincrement())
  spare_part_id  Int?
  user_id        Int?
  type           String?      @db.VarChar(50)
  quantity       Int
  stock_before   Int          @default(0)
  stock_after    Int          @default(0)
  note           String?
  reference_id   Int?
  reference_type String?      @db.VarChar(50)
  created_at     DateTime?    @default(now()) @db.Timestamptz(6)
  spare_parts    spare_parts? @relation(fields: [spare_part_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users?       @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model transaction_items {
  id             Int           @id @default(autoincrement())
  transaction_id Int?
  item_type      String?       @db.VarChar(50)
  spare_part_id  Int?
  item_name      String        @db.VarChar(255)
  quantity       Int           @default(1)
  unit_price     Decimal       @default(0) @db.Decimal(15, 2)
  total_price    Decimal?      @default(dbgenerated("((quantity)::numeric * unit_price)")) @db.Decimal(15, 2)
  created_at     DateTime?     @default(now()) @db.Timestamptz(6)
  spare_parts    spare_parts?  @relation(fields: [spare_part_id], references: [id], onUpdate: NoAction)
  transactions   transactions? @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model transactions {
  id                Int                 @id @default(autoincrement())
  invoice_number    String              @unique @db.VarChar(100)
  customer_id       Int?
  vehicle_id        Int?
  user_id           Int?
  transaction_date  DateTime            @db.Date
  total_amount      Decimal             @default(0) @db.Decimal(15, 2)
  paid_amount       Decimal             @default(0) @db.Decimal(15, 2)
  payment_method    String?             @default("cash") @db.VarChar(50)
  payment_status    String?             @default("belum_bayar") @db.VarChar(50)
  notes             String?
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  transaction_items transaction_items[]
  customers         customers?          @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  vehicles          vehicles?           @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction)
  users             users?              @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model users {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(255)
  email           String            @unique @db.VarChar(255)
  password_hash   String            @db.VarChar(255)
  role            String?           @default("kasir") @db.VarChar(50)
  is_active       Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?         @default(now()) @db.Timestamptz(6)
  deleted_at      DateTime?         @db.Timestamptz(6)
  opnames         opnames[]
  stock_movements stock_movements[]
  transactions    transactions[]
}

model vehicles {
  id           Int            @id @default(autoincrement())
  customer_id  Int?
  plate_number String         @unique @db.VarChar(50)
  type         String?        @db.VarChar(50)
  brand        String?        @db.VarChar(100)
  model        String?        @db.VarChar(100)
  year         Int?
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?      @default(now()) @db.Timestamptz(6)
  transactions transactions[]
  customers    customers?     @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model wa_notifications {
  id            Int          @id @default(autoincrement())
  spare_part_id Int?
  wa_number     String       @db.VarChar(20)
  message_body  String
  status        String?      @default("pending") @db.VarChar(20)
  sent_at       DateTime?    @db.Timestamptz(6)
  created_at    DateTime?    @default(now()) @db.Timestamptz(6)
  spare_parts   spare_parts? @relation(fields: [spare_part_id], references: [id], onUpdate: NoAction)
}
